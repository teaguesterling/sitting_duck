query IT
SELECT type, semantic_type_to_string(semantic_type) as sem_type
FROM read_ast('test/data/dart/sample.dart')
WHERE type = 'cascade_section'
LIMIT 1;
----
cascade_section	COMPUTATION_ACCESS
