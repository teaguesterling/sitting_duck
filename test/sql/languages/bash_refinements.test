query IT
SELECT type, semantic_type_to_string(semantic_type) as sem_type
FROM read_ast('test/data/bash/simple.sh')
WHERE type = 'else_clause'
LIMIT 1;
----
else_clause	FLOW_CONDITIONAL

# Test: if keyword should be FLOW_CONDITIONAL
query IT
SELECT type, semantic_type_to_string(semantic_type) as sem_type
FROM read_ast('test/data/bash/simple.sh')
WHERE type = 'if'
LIMIT 1;
----
