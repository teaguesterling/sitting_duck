LIMIT 1;
----
#	OPERATOR_ARITHMETIC

# Test: == operator should be OPERATOR_COMPARISON
query IT
SELECT type, semantic_type_to_string(semantic_type) as sem_type
FROM read_ast('test/data/lua/simple.lua', context := 'native')
WHERE type = '=='
LIMIT 1;
----
==	OPERATOR_COMPARISON

