# name: test/sql/dynamic_languages/register_language.test
# description: Runtime tree-sitter grammar registration via register_language()
# group: [dynamic_languages]

require sitting_duck

# Requires the test grammar library built by `make test-grammar-lib`.
# Run with: SITTING_DUCK_TEST_GRAMMAR_DIR=build/test_grammars make test
require-env SITTING_DUCK_TEST_GRAMMAR_DIR

# register_language() loads native code, so it is disabled by default.
statement ok
SET sitting_duck_enable_runtime_grammars = true;

# Happy path: register the JSON grammar under a new name with a symbol override.
# overwrite := true keeps the file re-runnable within one process (registration
# is process-global).
query TIIT
SELECT language, CAST(abi_version >= 13 AS INTEGER), node_type_count, status
FROM register_language('jsond', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                       symbol := 'tree_sitter_json',
                       extensions := ['jsond'],
                       aliases := ['jsondyn'],
                       overwrite := true);
----
jsond	1	0	registered

# Node-count parity with the built-in json language (same grammar, same input)
query I
SELECT (SELECT count(*) FROM parse_ast('{"a": [1, 2]}', 'jsond')) =
       (SELECT count(*) FROM parse_ast('{"a": [1, 2]}', 'json'));
----
true

# Without a semantic config, unknown node types degrade to PARSER_CONSTRUCT
# and the heuristic name extractor finds no name for `pair` (empty string,
# matching the built-in adapters' no-name convention)
query TT
SELECT semantic_type::VARCHAR, CASE WHEN name = '' THEN '<no name>' ELSE name END
FROM parse_ast('{"a": 1}', 'jsond') WHERE type = 'pair';
----
PARSER_CONSTRUCT	<no name>

# Aliases resolve to the registered language
query I
SELECT count(*) > 0 FROM parse_ast('{}', 'jsondyn');
----
true

# Duplicate registration without overwrite errors
statement error
SELECT * FROM register_language('jsond', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                                symbol := 'tree_sitter_json');
----
<REGEX>:.*already registered.*

# Re-register with a JSON semantic config (overwrite)
query IT
SELECT node_type_count, status
FROM register_language('jsond', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                       symbol := 'tree_sitter_json',
                       config := 'test/data/dynamic_grammars/jsond_types.json',
                       extensions := ['jsond'],
                       aliases := ['jsondyn'],
                       overwrite := true);
----
9	registered

# Config-driven semantic types (SEMANTIC_TYPE rendering masks refinement bits)
query TT
SELECT type, semantic_type::VARCHAR
FROM parse_ast('{"a": [1, true]}', 'jsond')
WHERE type IN ('document', 'pair', 'array')
ORDER BY type;
----
array	LITERAL_STRUCTURED
document	DEFINITION_MODULE
pair	DEFINITION_VARIABLE

# Config-driven name extraction: FIRST_CHILD on pair extracts the key string
query T
SELECT name FROM parse_ast('{"a": [1, true]}', 'jsond') WHERE type = 'pair';
----
"a"

# An alias colliding with an existing dynamic language name is rejected
statement error
SELECT * FROM register_language('aliassteal', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                                symbol := 'tree_sitter_json', aliases := ['jsond']);
----
<REGEX>:.*already registered.*

# A language name colliding with an existing dynamic alias is rejected
statement error
SELECT * FROM register_language('jsondyn', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                                symbol := 'tree_sitter_json');
----
<REGEX>:.*already registered.*

# NULL named parameters are rejected cleanly
statement error
SELECT * FROM register_language('nulltest', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                                symbol := NULL);
----
<REGEX>:.*cannot be NULL.*

# Registering over a built-in language name is always rejected
statement error
SELECT * FROM register_language('python', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                                symbol := 'tree_sitter_json', overwrite := true);
----
<REGEX>:.*built-in.*

# Registering an alias that collides with a built-in alias is rejected
statement error
SELECT * FROM register_language('pysteal', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                                symbol := 'tree_sitter_json', aliases := ['py']);
----
<REGEX>:.*built-in.*

# Language names must match [a-z][a-z0-9_]*
statement error
SELECT * FROM register_language('Bad-Name', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so');
----
<REGEX>:.*language name.*

# Nonexistent library path produces a clear load error
statement error
SELECT * FROM register_language('nolib', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libdoes_not_exist.so');
----
<REGEX>:.*Failed to load grammar library.*

# Missing symbol produces a clear resolution error
statement error
SELECT * FROM register_language('badsym', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                                symbol := 'tree_sitter_nonexistent');
----
<REGEX>:.*Failed to resolve symbol.*

# Dynamic languages appear in ast_supported_languages with their extensions
query TTTI
SELECT language, extensions::VARCHAR, parser_type, node_type_count
FROM ast_supported_languages()
WHERE language = 'jsond';
----
jsond	[jsond]	tree-sitter (dynamic)	9

# Extension auto-detection consults dynamic registrations
query T
SELECT detect_language('some/file.jsond');
----
jsond

# read_ast auto-detects the dynamic language from the file extension
query I
SELECT count(*) > 0 FROM read_ast('test/data/dynamic_grammars/sample.jsond');
----
true

# read_ast with explicit dynamic language and glob
query I
SELECT count(*) > 0 FROM read_ast('test/data/dynamic_grammars/*.jsond', 'jsond');
----
true

# Unsupported-language errors point at register_language()
statement error
SELECT * FROM parse_ast('{}', 'not_a_language');
----
<REGEX>:.*register_language.*
