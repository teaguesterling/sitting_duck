# name: test/sql/qualified_name.test
# description: Test qualified_name column for definition node disambiguation
# group: [sql]

require sitting_duck

statement ok
LOAD sitting_duck;

# =============================================================================
# Test 1: Basic qualified_name format for top-level definitions
# =============================================================================

# Top-level variable gets V[name]
query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE name = 'MY_CONST' AND is_definition(semantic_type);
----
MY_CONST	V[MY_CONST]

# Top-level function gets F[name]
query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE name = 'top_level_function' AND is_definition(semantic_type);
----
top_level_function	F[top_level_function]

# =============================================================================
# Test 2: Class-scoped definitions
# =============================================================================

# Classes get C[name]
query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE name IN ('User', 'Account') AND is_definition(semantic_type)
ORDER BY start_line;
----
User	C[User]
Account	C[Account]

# =============================================================================
# Test 3: Disambiguation of same-named methods (__init__)
# =============================================================================

# This is the KEY use case: three __init__ methods, all disambiguated
query I
SELECT ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE name = '__init__' AND is_definition(semantic_type)
ORDER BY start_line;
----
C[User] F[__init__]
C[Account] F[__init__]
C[Account] C[Settings] F[__init__]

# =============================================================================
# Test 4: Nested class scoping
# =============================================================================

# Settings is nested inside Account
query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE name = 'Settings' AND is_definition(semantic_type);
----
Settings	C[Account] C[Settings]

# =============================================================================
# Test 5: Nested function scoping
# =============================================================================

query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE name = 'nested_helper' AND is_definition(semantic_type);
----
nested_helper	F[top_level_function] F[nested_helper]

# =============================================================================
# Test 6: Method in class
# =============================================================================

query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE name = 'validate' AND is_definition(semantic_type);
----
validate	C[User] F[validate]

# =============================================================================
# Test 7: Non-definition nodes get NULL qualified_name
# =============================================================================

query I
SELECT COUNT(*)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE qualified_name IS NOT NULL AND NOT is_definition(semantic_type);
----
0

# =============================================================================
# Test 8: parse_ast inline also produces qualified_name
# =============================================================================

query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM parse_ast('
class Foo:
    def bar(self):
        pass
', 'python')
WHERE qualified_name IS NOT NULL
ORDER BY start_line;
----
Foo	C[Foo]
bar	C[Foo] F[bar]

# =============================================================================
# Test 9: Partial matching with LIKE
# =============================================================================

# All definitions nested inside User class (not User itself)
query I
SELECT ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE ast_qualified_name_as_string(qualified_name) LIKE 'C[User] %'
ORDER BY start_line;
----
C[User] F[__init__]
C[User] F[__init__] V[name]
C[User] F[validate]

# =============================================================================
# Test 10: All definitions have qualified_name (no definition left NULL)
# =============================================================================

query I
SELECT COUNT(*)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE is_definition(semantic_type) AND name != '' AND qualified_name IS NULL;
----
0

# =============================================================================
# Test 11: Filter by kind — anchored prefix match finds all functions
# =============================================================================

# Match any qualified_name containing F[ — includes functions themselves
# AND nested definitions inside functions (e.g., V[x] inside F[foo])
query I
SELECT COUNT(*)
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE ast_qualified_name_as_string(qualified_name) LIKE '%F[%';
----
10

# =============================================================================
# Test 12: A variable literally named "F" does not match the function filter
# =============================================================================

# V[F] doesn't contain 'F[' — format avoids the single-letter-name collision
query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM parse_ast('F = 1', 'python')
WHERE is_definition(semantic_type) AND name = 'F';
----
F	V[F]

# =============================================================================
# Test 13: Import statements get I[name] prefix
# =============================================================================

# Python aliased import: import_statement gets I[numpy], alias gets I[np]
query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM parse_ast('import numpy as np', 'python')
WHERE ast_qualified_name_as_string(qualified_name) LIKE 'I[%'
ORDER BY name;
----
np	I[np]
numpy	I[numpy]

# =============================================================================
# Test 14: Filter by import kind with 'I[' prefix pattern
# =============================================================================

# 4 nodes: import_statement os, import_statement sys, import_statement numpy, aliased_import np
query I
SELECT COUNT(*)
FROM parse_ast('
import os
import sys
import numpy as np
', 'python')
WHERE ast_qualified_name_as_string(qualified_name) LIKE 'I[%';
----
4

# =============================================================================
# Test 15: JavaScript export specifiers get E[name] prefix
# =============================================================================

query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM parse_ast('export { foo, bar }', 'javascript')
WHERE ast_qualified_name_as_string(qualified_name) LIKE 'E[%'
ORDER BY name;
----
bar	E[bar]
foo	E[foo]

# =============================================================================
# Test 16: Collision suffix — two definitions with the same (prefix, name)
# in the same scope produce "base" and "base[2]". First stays clean.
# =============================================================================

# Two module-level `counter = ...` rebinding statements.
query I
SELECT ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_name_collisions.py', 'python')
WHERE name = 'counter' AND is_definition(semantic_type)
ORDER BY start_line;
----
V[counter]
V[counter][2]

# =============================================================================
# Test 17: Collision counter increments monotonically (third occurrence → [3])
# =============================================================================

query I
SELECT ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_name_collisions.py', 'python')
WHERE name = 'total' AND is_definition(semantic_type)
ORDER BY start_line;
----
V[total]
V[total][2]
V[total][3]

# =============================================================================
# Test 18: Counter resets at scope boundaries — the second function's
# "result" is its scope's first occurrence, so it stays unsuffixed.
# =============================================================================

# The 'transform_items' function has two 'result' locals → collision
# The 'accumulator' function has one 'result' local → no suffix
query II
SELECT start_line, ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_name_collisions.py', 'python')
WHERE name = 'result' AND is_definition(semantic_type)
ORDER BY start_line;
----
22	F[transform_items] V[result]
23	F[transform_items] V[result][2]
31	F[accumulator] V[result]

# =============================================================================
# Test 19: Nested method scope — Container.__init__ has two `self.* = value`
# assignments, which record the RHS identifier as V[value] twice in that
# method's scope. The second gets a [2] suffix.
# =============================================================================

query I
SELECT ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_name_collisions.py', 'python')
WHERE name = 'value' AND is_definition(semantic_type)
ORDER BY start_line;
----
C[Container] F[__init__] V[value]
C[Container] F[__init__] V[value][2]

# =============================================================================
# Test 20: Method redefinition — same class scope, same function name.
# =============================================================================

query I
SELECT ast_qualified_name_as_string(qualified_name)
FROM read_ast('test/data/python/qualified_name_collisions.py', 'python')
WHERE name = 'reset' AND is_definition(semantic_type)
ORDER BY start_line;
----
C[Container] F[reset]
C[Container] F[reset][2]

# =============================================================================
# Test 21: V[x] and F[x] in the same scope do NOT collide with each other —
# the counter is keyed on the full (prefix, name) tuple, not just the name.
# =============================================================================

query II
SELECT name, ast_qualified_name_as_string(qualified_name)
FROM parse_ast('
x = 1
def x():
    pass
', 'python')
WHERE name = 'x' AND is_definition(semantic_type)
ORDER BY start_line;
----
x	V[x]
x	F[x]

# =============================================================================
# Test 22: LIKE '%[name]%' still finds both unsuffixed and suffixed forms
# because the [name] substring is preserved in both.
# =============================================================================

query I
SELECT COUNT(*)
FROM read_ast('test/data/python/qualified_name_collisions.py', 'python')
WHERE ast_qualified_name_as_string(qualified_name) LIKE '%[counter]%';
----
2

query I
SELECT COUNT(*)
FROM read_ast('test/data/python/qualified_name_collisions.py', 'python')
WHERE ast_qualified_name_as_string(qualified_name) LIKE '%[total]%';
----
3

# =============================================================================
# Test 23: Struct-list form — filter by semantic_type inside the list
# =============================================================================

# Find all definitions whose path contains a class scope (any class ancestor).
query I
SELECT COUNT(*) > 0
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE len(list_filter(qualified_name,
                      s -> is_class_definition(s.semantic_type))) > 0;
----
true

# =============================================================================
# Test 24: Struct-list form — get the innermost enclosing class name
# =============================================================================

query II
SELECT name,
       (list_reverse(list_filter(qualified_name,
                                 s -> is_class_definition(s.semantic_type))))[1].name
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE name = 'validate' AND is_function_definition(semantic_type);
----
validate	User

# =============================================================================
# Test 25: Struct-list form — depth-based filter (top-level definitions only)
# =============================================================================

# Top-level functions have a single-segment qualified_name.
query I
SELECT name
FROM read_ast('test/data/python/qualified_names.py', 'python')
WHERE len(qualified_name) = 1
  AND is_function_definition(semantic_type)
ORDER BY start_line;
----
top_level_function

# =============================================================================
# Test 26: Struct-list form — explicit index is always >= 1 on definitions
# =============================================================================

query I
SELECT COUNT(*)
FROM read_ast('test/data/python/qualified_name_collisions.py', 'python')
WHERE is_definition(semantic_type)
  AND name != ''
  AND len(qualified_name) > 0
  AND qualified_name[-1].index < 1;
----
0
