# name: test/sql/dynamic_languages/register_language_external_access.test
# description: register_language() is gated on enable_external_access
# group: [dynamic_languages]

require sitting_duck

require-env SITTING_DUCK_TEST_GRAMMAR_DIR

# Separate test file: enable_external_access cannot be reliably re-enabled
# within a session, so this must not precede other dynamic language tests.

statement ok
SET enable_external_access = false;

statement error
SELECT * FROM register_language('extblocked', '${SITTING_DUCK_TEST_GRAMMAR_DIR}/libjson_dyn.so',
                                symbol := 'tree_sitter_json');
----
<REGEX>:.*[Pp]ermission.*
