# =============================================================================
# 14. BARE TYPE PREFIX MATCHING
# =============================================================================
# Bare `if` matches if_statement, if_clause, etc. via LIKE prefix.

# Python: bare `if` matches keyword token and if_statement
query I
SELECT DISTINCT type FROM ast_select('test/data/python/css_selectors_test.py', 'if')
ORDER BY type;
----
if
if_statement

# Python: bare `return` matches keyword and return_statement
query I
SELECT DISTINCT type FROM ast_select('test/data/python/css_selectors_test.py', 'return')
ORDER BY type;
----
return
return_statement

# JavaScript: bare `if` matches keyword and if_statement
query I
SELECT DISTINCT type FROM ast_select('test/data/javascript/css_selectors_test.js', 'if')
ORDER BY type;
----
if
if_statement

# Go: bare `if` matches keyword and if_statement
query I
SELECT DISTINCT type FROM read_ast('test/data/go/css_selectors_test.go')
WHERE type = 'if' OR type LIKE 'if_%'
ORDER BY type
LIMIT 5;
----
if
if_statement

# Rust: bare `if` matches keyword and if_expression
query I
SELECT DISTINCT type FROM read_ast('test/data/rust/css_selectors_test.rs')
WHERE type = 'if' OR type LIKE 'if_%'
ORDER BY type
LIMIT 5;
----
if
if_expression

