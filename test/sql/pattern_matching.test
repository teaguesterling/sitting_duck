# name: test/sql/pattern_matching.test
# group: [sql]

# Test pattern matching macros for AST querying
# Pattern matching macros are embedded in the extension

require sitting_duck

statement ok
LOAD sitting_duck;

# =============================================================================
# Helper Macro Tests
# =============================================================================

# Test is_pattern_wildcard
query I
SELECT is_pattern_wildcard('__X__');
----
true

query I
SELECT is_pattern_wildcard('__');
----
true

query I
SELECT is_pattern_wildcard('__FUNC__');
----
true

query I
SELECT is_pattern_wildcard('__init__');
----
false

query I
SELECT is_pattern_wildcard('foo');
----
false

query I
SELECT is_pattern_wildcard(NULL);
----
false

# Test wildcard_capture_name
query I
SELECT wildcard_capture_name('__X__');
----
X

query I
SELECT wildcard_capture_name('__FUNC__');
----
FUNC

query I
SELECT wildcard_capture_name('__');
----
NULL

query I
SELECT wildcard_capture_name('foo');
----
NULL

# =============================================================================
# Pattern Cleaning Tests (Both Syntaxes)
# =============================================================================

# Legacy syntax cleaning
query I
SELECT clean_pattern('%__BODY<*>__%');
----
__BODY__

query I
SELECT clean_pattern('%__X<+>__%');
----
__X__

query I
SELECT clean_pattern('%__<*>__%');
----
__

# HTML syntax cleaning
query I
SELECT clean_pattern('%__<BODY*>__%');
----
__BODY__

query I
SELECT clean_pattern('%__<X+>__%');
----
__X__

query I
SELECT clean_pattern('%__<*>__%');
----
__

query I
SELECT clean_pattern('%__<X* type=identifier>__%');
----
__X__

# Mixed pattern cleaning
query I
SELECT clean_pattern('def __F__(__): %__<BODY*>__% return __Y__');
----
def __F__(__): __BODY__ return __Y__

# =============================================================================
# Variadic Detection Tests
# =============================================================================

# Legacy syntax variadic detection
query I
SELECT pattern_has_variadic('%__BODY<*>__%');
----
true

query I
SELECT pattern_has_variadic('%__X<+>__%');
----
true

query I
SELECT pattern_has_variadic('__X__');
----
false

# HTML syntax variadic detection
query I
SELECT pattern_has_variadic('%__<BODY*>__%');
----
true

query I
SELECT pattern_has_variadic('%__<X+>__%');
----
true

query I
SELECT pattern_has_variadic('%__<X type=identifier>__%');
----
false

# =============================================================================
# HTML Wildcard Parser Tests
# =============================================================================

# Basic modifiers
query I
SELECT parse_html_wildcard('<BODY*>').name;
----
BODY

query I
SELECT parse_html_wildcard('<BODY*>').variadic_star;
----
true

query I
SELECT parse_html_wildcard('<ARGS+>').variadic_plus;
----
true

query I
SELECT parse_html_wildcard('<SKIP~>').negate;
----
true

query I
SELECT parse_html_wildcard('<DOCSTRING?>').optional;
----
true

query I
SELECT parse_html_wildcard('<BODY**>').recursive;
----
true

# Combined modifiers
query II
SELECT parse_html_wildcard('<NOISE*~>').variadic_star, parse_html_wildcard('<NOISE*~>').negate;
----
true	true

# ** should not trigger variadic_star
query II
SELECT parse_html_wildcard('<BODY**>').variadic_star, parse_html_wildcard('<BODY**>').recursive;
----
false	true

# Anonymous wildcards
query I
SELECT parse_html_wildcard('<*>').name;
----
_

query I
SELECT parse_html_wildcard('<+>').name;
----
_

query I
SELECT parse_html_wildcard('<_ type=string>').name;
----
_

# Attribute parsing
query I
SELECT parse_html_wildcard('<X* type=identifier>').type_constraint;
----
identifier

query I
SELECT parse_html_wildcard('<X* not-type=comment>').not_type_constraint;
----
comment

query I
SELECT parse_html_wildcard('<X max-descendants=10>').max_descendants;
----
10

query I
SELECT parse_html_wildcard('<X min-descendants=5>').min_descendants;
----
5

query I
SELECT parse_html_wildcard('<X* min-children=2>').min_children;
----
2

query I
SELECT parse_html_wildcard('<X* max-children=5>').max_children;
----
5

query I
SELECT parse_html_wildcard('<X* name=self>').name_constraint;
----
self

query I
SELECT parse_html_wildcard('<X semantic=LITERAL>').semantic_constraint;
----
LITERAL

# =============================================================================
# Pattern Parsing Tests
# =============================================================================

# Create test table for pattern parsing (uses parse_ast for inline patterns)
statement ok
CREATE TEMP TABLE pattern_test AS
SELECT * FROM ast_pattern('foo(__X__)', 'python');

query I
SELECT count(*) FROM pattern_test WHERE is_wildcard = true;
----
1

query I
SELECT capture_name FROM pattern_test WHERE is_wildcard = true;
----
X

# =============================================================================
# Basic Pattern Matching Tests (file-path signature)
# =============================================================================

# Simple pattern: find single-arg function calls (print, eval, exec, add_numbers)
query I
SELECT count(*) FROM ast_match('test/data/python/macros/pattern_test.py', '__F__(__X__)');
----
4

# =============================================================================
# Variadic Pattern Matching Tests
# =============================================================================

# Without variadic: exact structure required
# add_numbers has simple body so it matches, greet has print() before return so it won't
query I
SELECT count(*) FROM ast_match('test/data/python/macros/pattern_test.py', 'def __F__(__): return __Y__');
----
1

# With variadic (* = 0 or more): matches ALL functions with return (both add_numbers and greet)
query I
SELECT count(*) FROM ast_match('test/data/python/macros/pattern_test.py',
    'def __F__(__):
    %__BODY<*>__%
    return __Y__');
----
2

# With variadic (HTML syntax): same result
query I
SELECT count(*) FROM ast_match('test/data/python/macros/pattern_test.py',
    'def __F__(__):
    %__<BODY*>__%
    return __Y__');
----
2

# Anonymous variadic (legacy)
query I
SELECT count(*) FROM ast_match('test/data/python/macros/pattern_test.py',
    'def __F__(__):
    %__<*>__%
    return __Y__');
----
2

# =============================================================================
# Capture Extraction Tests
# =============================================================================

# Multiple captures - both functions match with * variadic
query II
SELECT captures['F'][1].name, captures['Y'][1].peek
FROM ast_match('test/data/python/macros/pattern_test.py',
    'def __F__(__):
    %__<BODY*>__%
    return __Y__')
ORDER BY captures['F'][1].name;
----
add_numbers	x + y
greet	name

# =============================================================================
# Cross-Language Matching Tests
# =============================================================================

# Semantic type matching within a single language
query I
SELECT count(*) FROM ast_match('test/data/python/macros/pattern_test.py', '__F__(__X__)', match_by := 'semantic_type')
WHERE captures['F'][1].name = 'print';
----
1

# =============================================================================
# ast_capture Convenience Macro Tests
# =============================================================================

# ast_capture should work like captures['X'][1]
query I
SELECT ast_capture(captures, 'F').name FROM ast_match('test/data/python/macros/star_test.py', 'def __F__(__): return __Y__');
----
simple

# =============================================================================
# LIST-Valued Capture Tests
# =============================================================================

# Single wildcard captures should be 1-element lists
query I
SELECT length(captures['F']) FROM ast_match('test/data/python/macros/star_test.py', 'def __F__(__): return __Y__');
----
1

# =============================================================================
# Variadic Capture Tests
# =============================================================================

# Variadic capture should return list of matched body nodes
# add_numbers: 0 (only return), greet: 1 (print before return)
query II
SELECT captures['F'][1].name, length(captures['BODY'])
FROM ast_match('test/data/python/macros/pattern_test.py',
    'def __F__(__):
    %__BODY<*>__%
    return __Y__')
ORDER BY captures['F'][1].name;
----
add_numbers	0
greet	1

# process() has validate() and transform() before return - BODY captures both
query I
SELECT length(captures['BODY'])
FROM ast_match('test/data/python/macros/variadic_test.py',
    'def __F__(__):
    %__BODY<*>__%
    return __Y__');
----
2

# * variadic with zero matches should produce empty list
# simple() should match with empty BODY list (only has return, nothing before it)
query II
SELECT captures['F'][1].name, length(captures['BODY'])
FROM ast_match('test/data/python/macros/star_test.py',
    'def __F__(__):
    %__BODY<*>__%
    return __Y__')
ORDER BY captures['F'][1].name;
----
multi	1
simple	0

# + variadic should NOT match zero nodes
# Only multi() should match (has statement before return)
query I
SELECT count(*)
FROM ast_match('test/data/python/macros/star_test.py',
    'def __F__(__):
    %__BODY<+>__%
    return __Y__');
----
1

query I
SELECT captures['F'][1].name
FROM ast_match('test/data/python/macros/star_test.py',
    'def __F__(__):
    %__BODY<+>__%
    return __Y__');
----
multi

# =============================================================================
# Same-Name Constraint Tests
# =============================================================================

# __X__ == __X__ should match only self-equality (a==a, x==x)
query I
SELECT count(*)
FROM ast_match('test/data/python/macros/equality_test.py', '__X__ == __X__');
----
2

# __X__ + __X__ should match only b+b
query I
SELECT count(*)
FROM ast_match('test/data/python/macros/equality_test.py', '__X__ + __X__');
----
1

query I
SELECT captures['X'][1].peek
FROM ast_match('test/data/python/macros/equality_test.py', '__X__ + __X__');
----
b

# __X__ == __Y__ (different names = no constraint) should match all equality exprs
query I
SELECT count(*)
FROM ast_match('test/data/python/macros/equality_test.py', '__X__ == __Y__');
----
3
