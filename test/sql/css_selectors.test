# name: test/sql/css_selectors.test
# group: [sql]

# Test CSS selector query language (ast_select)

require sitting_duck

statement ok
LOAD sitting_duck;

# =============================================================================
# Type Selectors
# =============================================================================

# Bare type selector finds all matching nodes
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition')
WHERE depth = 1
ORDER BY start_line;
----
shallow_return	2
return_in_if	5
deeply_nested_return	10
direct_execute	18
nested_execute	21
no_execute	28
outer_with_execute	32
outer_no_execute	37

# =============================================================================
# #name (ID) Selectors
# =============================================================================

# Type + name filter
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition#no_execute')
ORDER BY start_line;
----
no_execute	28

# =============================================================================
# .semantic (Class) Selectors
# =============================================================================

# .function matches function definitions (excluding keyword tokens)
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py', '.function')
WHERE depth = 1
ORDER BY start_line;
----
shallow_return	2
return_in_if	5
deeply_nested_return	10
direct_execute	18
nested_execute	21
no_execute	28
outer_with_execute	32
outer_no_execute	37

# Case-insensitive: .FUNCTION same as .function
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py', '.FUNCTION')
WHERE depth = 1
ORDER BY start_line;
----
shallow_return	2
return_in_if	5
deeply_nested_return	10
direct_execute	18
nested_execute	21
no_execute	28
outer_with_execute	32
outer_no_execute	37

# =============================================================================
# :has() Pseudo-Class
# =============================================================================

# Functions containing return_statement (should match ast_has results)
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:has(return_statement)')
ORDER BY start_line;
----
shallow_return	2
return_in_if	5
deeply_nested_return	10

# :has with #name filter
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:has(call#execute)')
ORDER BY start_line;
----
direct_execute	18
nested_execute	21
outer_with_execute	32
inner	33
outer_no_execute	37
inner	38

# =============================================================================
# :not(:has()) Pseudo-Class
# =============================================================================

# Functions NOT containing return_statement
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:not(:has(return_statement))')
ORDER BY start_line;
----
direct_execute	18
nested_execute	21
no_execute	28
outer_with_execute	32
inner	33
outer_no_execute	37
inner	38

# Functions NOT containing call to execute
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:not(:has(call#execute))')
ORDER BY start_line;
----
shallow_return	2
return_in_if	5
deeply_nested_return	10
no_execute	28

# =============================================================================
# Descendant Combinator (A B)
# =============================================================================

# Return statements inside if_statements (nested)
query I
SELECT COUNT(*)
FROM ast_select('test/data/python/macros/recursive_match.py',
    'if_statement return_statement');
----
2

# =============================================================================
# Sibling Combinator (A ~ B)
# =============================================================================

# Functions that follow other functions (all except the first)
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition ~ function_definition')
WHERE depth = 1
ORDER BY start_line;
----
return_in_if	5
deeply_nested_return	10
direct_execute	18
nested_execute	21
no_execute	28
outer_with_execute	32
outer_no_execute	37

# =============================================================================
# Compound Selectors
# =============================================================================

# .function:has(X):not(:has(Y)) — the compound query
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:has(call#execute):not(:has(return_statement))')
ORDER BY start_line;
----
direct_execute	18
nested_execute	21
outer_with_execute	32
inner	33
outer_no_execute	37
inner	38

# =============================================================================
# Wildcard Child Relaxation (parent_is_wildcard)
# =============================================================================

# JS class method matching: __M__ should match regardless of async keyword
query II
SELECT captures['C'][1].name as cls, captures['M'][1].name as method
FROM ast_match('test/data/javascript/simple.js',
    'class __C__ {
        __M__(__) { }
    }', 'javascript')
ORDER BY start_line
LIMIT 1;
----
Calculator	constructor
