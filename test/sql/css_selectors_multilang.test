# JavaScript: method_definition:first-child returns empty because `{` is sibling 0 in class_body.
# :nth-child(2) correctly finds first actual method in each class body.
query I
SELECT name FROM ast_select('test/data/javascript/css_selectors_test.js', 'method_definition:first-child')
ORDER BY name;
----

query I
SELECT name FROM ast_select('test/data/javascript/css_selectors_test.js', 'method_definition:nth-child(2)')
ORDER BY name;
----
constructor
constructor
constructor

# Python: classes after another class that have a speak method.
# CSS parser wraps as pseudo_class_selector(sibling_selector(...), :has(...));
# sel_pseudo_class_unwrap re-roots to the sibling_selector so the combinator
# CASE branch fires with the :has filter still applied.
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'class_definition ~ class_definition:has(function_definition#speak)')
ORDER BY name;
----
Cat
Dog

# JavaScript: class_body > method_definition:has(return_statement)
# Child combinator + :has on right side. Unwrap re-roots to child_selector.
query I
SELECT name FROM ast_select('test/data/javascript/css_selectors_test.js',
    'class_body > method_definition:has(return_statement)')
ORDER BY name, start_line;
----
area
area
area
describe
perimeter

# Python: classes that immediately follow another class AND have __init__
# Adjacent sibling + :has
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py',
    'class_definition + class_definition:has(function_definition#__init__)')
ORDER BY name;
----

# Python: descendant combinator + :has
# Functions containing a call to an if_statement descendant
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py',
    'class_definition function_definition:has(return_statement)')
ORDER BY name, start_line;
----
fetch
move
speak
speak
speak

# =============================================================================
# 16. :has() AND :not(:has()) WITH SEMANTIC CLASS (.class) inside
# =============================================================================
# Semantic class arguments inside :has() / :not() work regardless of whether
# the base selector is a .class or a type selector.

# .class:has(.class)
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', '.class:has(.function)')
ORDER BY name;
----
Animal
Cat
Dog

# .function:has(.call) — semantic base + semantic :has
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', '.function:has(.call)')
ORDER BY name, start_line;
----
main
make_animal
process_animals

# Rosetta Go: .function:has(.call)
query I
SELECT name FROM ast_select('test/data/rosetta/Lang/Go/Factorial/factorial-1.go', '.function:has(.call)')
ORDER BY name;
----
factorial
main

# type:has(.class) — type base + semantic :has. Must return the same set as
# .function:has(.call) above.
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'function_definition:has(.call)')
ORDER BY name, start_line;
----
main
make_animal
process_animals

# class_definition:has(.function) matches all 3 classes.
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'class_definition:has(.function)')
ORDER BY name;
----
Animal
Cat
Dog

# :not(:has(.class)) — functions without a descendant call
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', '.function:not(:has(.call))')
ORDER BY name, start_line;
----
__init__
fetch
move
purr
speak
speak
speak

# Compare with type-based :has(call) which works correctly
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', '.function:has(call)')
ORDER BY name, start_line;
----
main
make_animal
process_animals

# =============================================================================

# =============================================================================
# 17. ast_select_from (PRE-PARSED TABLE QUERIES)
# =============================================================================
# ast_select_from operates on a pre-parsed AST table so callers can parse
# once and run many selector queries without re-reading the source files.
# Every selector type should produce identical results to ast_select.

statement ok
CREATE TABLE py_ast AS SELECT * FROM read_ast('test/data/python/css_selectors_test.py');

# Type selector
query I
SELECT name FROM ast_select_from('py_ast', 'function_definition')
ORDER BY name, start_line;
----
__init__
fetch
main
make_animal
move
process_animals
purr
speak
speak
speak

# Class (semantic) selector
query I
SELECT name FROM ast_select_from('py_ast', '.class')
ORDER BY name;
----
Animal
Cat
Dog

# ID selector
query I
SELECT name FROM ast_select_from('py_ast', 'function_definition#main');
----
main

# Descendant combinator
query I
SELECT name FROM ast_select_from('py_ast', 'class_definition function_definition')
ORDER BY name, start_line;
----
__init__
fetch
move
purr
speak
speak
speak

# Adjacent sibling combinator
query I
SELECT name FROM ast_select_from('py_ast', 'class_definition + class_definition')
ORDER BY name;
----
Cat
Dog

# General sibling combinator
query I
SELECT name FROM ast_select_from('py_ast', 'class_definition ~ function_definition')
WHERE depth = 1
ORDER BY name;
----
main
make_animal
process_animals

# :has()
query I
SELECT name FROM ast_select_from('py_ast', 'function_definition:has(return_statement)')
ORDER BY name, start_line;
----
fetch
make_animal
move
speak
speak
speak

# :not(:has())
query I
SELECT name FROM ast_select_from('py_ast', 'function_definition:not(:has(return_statement))')
ORDER BY name;
----
__init__
main
process_animals
purr

# :has(.class) — exercises the Bug 1/2 fix path
query I
SELECT name FROM ast_select_from('py_ast', 'function_definition:has(.call)')
ORDER BY name, start_line;
----
main
make_animal
process_animals

# Combinator + pseudo-class on right side — exercises the Bug 3 fix path
query I
SELECT name FROM ast_select_from('py_ast',
    'class_definition ~ class_definition:has(function_definition#speak)')
ORDER BY name;
----
Cat
Dog

# Compound selector
query I
SELECT name FROM ast_select_from('py_ast', 'class_definition:has(function_definition#speak):not(:has(function_definition#fetch))')
ORDER BY name;
----
Animal
Cat

# :named
query I
SELECT name FROM ast_select_from('py_ast', 'function_definition:named')
ORDER BY name, start_line;
----
__init__
fetch
main
make_animal
move
process_animals
purr
speak
speak
speak

statement ok
DROP TABLE py_ast;

# ast_select_from with a different language (pattern language auto-detected from the table)
statement ok
CREATE TABLE js_ast AS SELECT * FROM read_ast('test/data/javascript/css_selectors_test.js');

query I
SELECT name FROM ast_select_from('js_ast', '.function')
ORDER BY name, start_line;
----
add
area
area
area
constructor
constructor
constructor
describe
fetchShape
greet
perimeter
processShapes

query I
SELECT name FROM ast_select_from('js_ast', 'class_declaration:has(method_definition#constructor)')
ORDER BY name;
----
Circle
Shape
Square

query I
SELECT name FROM ast_select_from('js_ast', 'function_declaration + function_declaration')
ORDER BY name;
----
add
processShapes

statement ok
DROP TABLE js_ast;

# =============================================================================
# 18. ROSETTA CODE EXAMPLES — cross-language selector consistency
# =============================================================================

# All Rosetta factorial implementations should find functions
query I
SELECT name FROM ast_select('test/data/rosetta/Lang/Python/Factorial/factorial-2.py', '.function')
ORDER BY name;
----
factorial

query I
SELECT name FROM ast_select('test/data/rosetta/Lang/Go/Factorial/factorial-1.go', '.function')
ORDER BY name;
----
factorial
main

query I
SELECT name FROM ast_select('test/data/rosetta/Lang/Rust/Factorial/factorial.rs', '.function')
ORDER BY name;
----
factorial_iterative
factorial_recursive
main

query I
SELECT name FROM ast_select('test/data/rosetta/Lang/JavaScript/Factorial/factorial-1.js', '.function')
ORDER BY name;
----
factorial

# Rosetta abstract types: .class across languages
query I
SELECT name FROM ast_select('test/data/rosetta/Lang/Python/Abstract-type/abstract-type-1.py', '.class')
ORDER BY name;
----
BaseQueue

# Go: .class returns struct/interface types (names are on parent type_spec)
query I
SELECT type FROM ast_select('test/data/rosetta/Lang/Go/Abstract-type/abstract-type.go', '.class')
ORDER BY type;
----
interface_type
struct_type
struct_type

# Rust: .class in abstract type
query I
SELECT name FROM ast_select('test/data/rosetta/Lang/Rust/Abstract-type/abstract-type-1.rs', '.class')
ORDER BY name;
----
Shape

# Rosetta: :has(call) works with type selectors across languages
query I
SELECT name FROM ast_select('test/data/rosetta/Lang/Python/Factorial/factorial-2.py', 'function_definition:has(call)')
ORDER BY name;
----
factorial

query I
SELECT name FROM ast_select('test/data/rosetta/Lang/JavaScript/Factorial/factorial-1.js', 'function_declaration:has(if_statement)')
ORDER BY name;
----
factorial

# Rosetta Go: all functions/methods
query I
SELECT name FROM ast_select('test/data/rosetta/Lang/Go/Abstract-type/abstract-type.go', '.function')
ORDER BY name;
----
Cry
Cry
Cry
Kind
Kind
Kind
Name
Name
Name
bprint
main
