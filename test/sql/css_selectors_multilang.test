# =============================================================================
# 5. CHILD COMBINATOR (A > B)
# =============================================================================
# The child combinator tests direct parent-child AST relationships.
# This is where tree-sitter grammar structure matters: many languages have
# intermediate nodes (block, class_body, declaration_list) between
# the "conceptual parent" and child.

# Python: class > function returns EMPTY because Python's AST has:
#   class_definition > block > function_definition
# The block node is an intermediary. This is CORRECT behavior.
query I
SELECT COALESCE(name, '(none)') FROM ast_select('test/data/python/css_selectors_test.py', 'class_definition > function_definition')
ORDER BY name;
----

# Python: block > function correctly matches class methods
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'block > function_definition')
ORDER BY name, start_line;
----
__init__
fetch
move
purr
speak
speak
speak

# JavaScript: class_declaration > method_definition returns EMPTY because:
#   class_declaration > class_body > method_definition
query I
SELECT COALESCE(name, '(none)') FROM ast_select('test/data/javascript/css_selectors_test.js', 'class_declaration > method_definition')
ORDER BY name;
----

# JavaScript: class_body > method_definition correctly matches
query I
SELECT name FROM ast_select('test/data/javascript/css_selectors_test.js', 'class_body > method_definition')
ORDER BY name, start_line;
----
area
area
area
constructor
constructor
constructor
describe
perimeter

# JavaScript: class_declaration > class_body (direct child relationship)
query I
SELECT type FROM ast_select('test/data/javascript/css_selectors_test.js', 'class_declaration > class_body')
ORDER BY start_line;
----
class_body
class_body
class_body

# =============================================================================
# 6. ADJACENT SIBLING COMBINATOR (A + B)
# =============================================================================
# B immediately follows A at the same parent level.

# Python: class immediately followed by class (Dog follows Animal, Cat follows Dog)
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'class_definition + class_definition')
ORDER BY name;
----
Cat
Dog

# Python: class immediately followed by function (make_animal follows Cat)
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'class_definition + function_definition')
ORDER BY name;
----
make_animal

# JavaScript: function_declaration immediately followed by function_declaration
# add follows greet; processShapes follows fetchShape (async is still function_declaration)
query I
SELECT name FROM ast_select('test/data/javascript/css_selectors_test.js', 'function_declaration + function_declaration')
ORDER BY name;
----
add
processShapes

# JavaScript: class_declaration immediately followed by class_declaration
query I
SELECT name FROM ast_select('test/data/javascript/css_selectors_test.js', 'class_declaration + class_declaration')
ORDER BY name;
----
Circle
Square

# Go: function_declaration + method_declaration (Distance follows NewPoint)
query I
SELECT name FROM ast_select('test/data/go/css_selectors_test.go', 'function_declaration + method_declaration')
ORDER BY name;
----
Distance

# =============================================================================
# 7. GENERAL SIBLING COMBINATOR (A ~ B)
# =============================================================================
# B comes after A at the same parent level (not necessarily immediately).

# Python: top-level functions after any class
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'class_definition ~ function_definition')
WHERE depth = 1
ORDER BY name;
----
main
make_animal
process_animals

# Python: classes after another class (same result as adjacent since they're consecutive)
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'class_definition ~ class_definition')
ORDER BY name;
----
Cat
Dog

# JavaScript: function_declarations after a class_declaration
query I
SELECT name FROM ast_select('test/data/javascript/css_selectors_test.js', 'class_declaration ~ function_declaration')
ORDER BY name;
----
fetchShape
processShapes

# JavaScript: all function_declarations after first function_declaration
query I
SELECT name FROM ast_select('test/data/javascript/css_selectors_test.js', 'function_declaration ~ function_declaration')
ORDER BY name;
----
add
fetchShape
processShapes

# Go: method_declarations after function_declaration
query I
SELECT name FROM ast_select('test/data/go/css_selectors_test.go', 'function_declaration ~ method_declaration')
ORDER BY name;
----
Area
Distance
Perimeter
String

# Rosetta Go: method_declaration ~ method_declaration (methods following other methods)
query I
SELECT name FROM ast_select('test/data/rosetta/Lang/Go/Abstract-type/abstract-type.go', 'method_declaration ~ method_declaration')
ORDER BY name, start_line;
----
Cry
Cry
Kind
Name
Name

