# name: test/sql/ast_select_pseudo_classes.test
# group: [sql]

# Test ast_select pseudo-classes: positional, structural, scope, ordering

require sitting_duck

statement ok
LOAD sitting_duck;

# =============================================================================
# Standard CSS positional pseudo-classes
# =============================================================================

# :first-child — first sibling (sibling_index = 0)
# The nested `inner` functions are the only function_definitions at sibling_index 0
query II
SELECT name, depth
FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition:first-child')
ORDER BY start_line;
----
inner	3
inner	3

# :last-child — last sibling at depth 1
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition:last-child')
WHERE depth = 1;
----
outer_no_execute	37

# :nth-child(2) — second sibling (1-based) at depth 1
# shallow_return is sibling_index 1 (comment is 0), so nth-child(2)
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition:nth-child(2)')
WHERE depth = 1;
----
shallow_return	2

# :empty — nodes with no children
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py', ':empty');
----
true

# :root — depth = 0
query I
SELECT type FROM ast_select('test/data/python/macros/recursive_match.py', ':root');
----
module

# =============================================================================
# Custom structural pseudo-classes
# =============================================================================

# :named — has a non-empty name
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition:named');
----
10

# :syntax — syntax-only tokens (keywords, punctuation)
# Bare `if` matches both keyword and statement; if:syntax gets only keywords
query I
SELECT COUNT(DISTINCT type)
FROM ast_select('test/data/python/macros/recursive_match.py', 'if:syntax');
----
1

# :definition — NAME_DEFINITION flag
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:definition');
----
10

# :reference — NAME_REFERENCE flag
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py',
    'identifier:reference');
----
true

# :scope (bare) — nodes that are scope boundaries
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:scope');
----
10

# =============================================================================
# :scope(type) — within nearest ancestor scope
# =============================================================================

# return_statement:scope(function) — returns within their DIRECT function
# Should NOT count returns in nested functions as belonging to the outer function
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'return_statement:scope(function)');
----
5

# =============================================================================
# :precedes(type) and :follows(type)
# =============================================================================

# :precedes(function_definition) — comments that come before a function def
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'comment:precedes(function_definition)');
----
3

# :follows(class_definition) — functions defined after a class
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/qualified_names.py',
    'function_definition:follows(class_definition)');
----
true

# =============================================================================
# Compound pseudo-classes
# =============================================================================

# :named:definition — named definitions only
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    ':named:definition');
----
10

# function_definition:first-child:has(return_statement) — first-child functions with returns
# The inner functions are first-child and have no returns themselves
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:first-child:has(return_statement)');
----
0

# =============================================================================
# :not(:pseudo-class) — negation of arbitrary pseudo-classes
# =============================================================================

# The :is-called / :not(:is-called) pair should partition the set of functions
# exactly: every function is either called or not, never both, never neither.
query III
WITH t AS (
    SELECT COUNT(*) FILTER (WHERE true) AS total,
           COUNT(*) FILTER (WHERE is_called) AS called,
           COUNT(*) FILTER (WHERE NOT is_called) AS not_called
    FROM (
        SELECT name,
               EXISTS (
                   SELECT 1 FROM ast_select('test/data/python/sample_app.py', '.func:is-called') c
                   WHERE c.node_id = f.node_id
               ) AS is_called
        FROM ast_select('test/data/python/sample_app.py', '.func') f
    )
)
SELECT total, called, not_called FROM t;
----
20	13	7

# :not(:is-called) should return exactly the functions that :is-called doesn't
query I
SELECT COUNT(*) FROM ast_select('test/data/python/sample_app.py', '.func:not(:is-called)');
----
7

# :not(:is-referenced) partitions the function set with :is-referenced
# (In sample_app.py every method is referenced via self.method, so not_ref = 0.)
query II
SELECT
    (SELECT COUNT(*) FROM ast_select('test/data/python/sample_app.py', '.func:is-referenced'))
  + (SELECT COUNT(*) FROM ast_select('test/data/python/sample_app.py', '.func:not(:is-referenced)')),
    (SELECT COUNT(*) FROM ast_select('test/data/python/sample_app.py', '.func'));
----
20	20

# Compound: :exported:not(:is-referenced) — example from the docs
# Uses a data file with unambiguously exported definitions
query I
SELECT COUNT(*) >= 0 FROM ast_select('test/data/python/sample_app.py',
    ':exported:not(:is-referenced)');
----
true

# :not() should compose with other pseudo-classes on the same node
# .func:named:not(:is-called) — named functions that are never called
query I
SELECT COUNT(*) FROM ast_select('test/data/python/sample_app.py',
    '.func:named:not(:is-called)');
----
7

# :not(:has()) must still work via the original not_has_conditions path
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/sample_app.py',
    '.func:not(:has(return_statement))');
----
true

# =============================================================================
# Unknown pseudo-classes raise a clear error instead of silently matching
# =============================================================================

statement error
SELECT * FROM ast_select('test/data/python/sample_app.py', '.func:totallynotreal');
----
unknown pseudo-class

statement error
SELECT * FROM ast_select('test/data/python/sample_app.py', '.func:not(:alsonotreal)');
----
unknown pseudo-class

# =============================================================================
# Custom predicates via ast_selector_predicate_* macros
# Uses a mock ast_dispatch_predicate that hardcodes test predicates via CASE.
# In production, sitting_duck auto-loads func_apply and registers a real
# dispatcher that uses apply() for dynamic dispatch.
# =============================================================================

# Define test predicate macros (these register in duckdb_functions)
statement ok
CREATE OR REPLACE MACRO ast_selector_predicate_name_starts(node, prefix) AS (
    node.name IS NOT NULL AND starts_with(node.name, prefix)
);

statement ok
CREATE OR REPLACE MACRO ast_selector_predicate_is_deep(node, arg) AS (
    node.depth >= 3
);

# Mock dispatcher: routes by function name to hardcoded predicate implementations
statement ok
CREATE OR REPLACE MACRO ast_dispatch_predicate(fn, node, arg) AS (
    CASE fn
        WHEN 'ast_selector_predicate_name_starts'
            THEN node.name IS NOT NULL AND starts_with(node.name, arg)
        WHEN 'ast_selector_predicate_is_deep'
            THEN node.depth >= 3
        ELSE false
    END
);

# Custom predicate with argument — 2 functions start with "outer"
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:name_starts("outer")');
----
2

# Custom predicate with no argument (arg is NULL)
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:is_deep');
----
true

# Negation: :not(:custom_pred)
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:not(:is_deep)');
----
true

# Custom predicate combined with built-in pseudo-class
# :named:is_deep — named function definitions at depth >= 3 (the 2 inner functions)
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:named:is_deep');
----
2

# Discoverability: registered predicates appear in duckdb_functions()
query I
SELECT COUNT(*) >= 2 FROM duckdb_functions()
WHERE function_name LIKE 'ast_selector_predicate_%';
----
true

# Error: unknown custom predicate (no matching macro registered)
statement error
SELECT * FROM ast_select('test/data/python/sample_app.py', '.func:no_such_predicate');
----
unknown pseudo-class
