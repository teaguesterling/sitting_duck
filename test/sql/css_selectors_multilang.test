# name: test/sql/css_selectors_multilang.test
# group: [sql]

# Comprehensive CSS selector tests across multiple languages.
# Tests type selectors, ID selectors, class (semantic) selectors,
# combinators (descendant, child, adjacent sibling, general sibling),
# pseudo-classes (:has, :not, :first-child, :last-child, :named, :definition, :scope),
# and ast_select_from (pre-parsed table queries).
#
# Test fixtures:
#   test/data/python/css_selectors_test.py
#   test/data/javascript/css_selectors_test.js
#   test/data/rust/css_selectors_test.rs
#   test/data/go/css_selectors_test.go
#   test/data/rosetta/Lang/*/Factorial/*
#   test/data/rosetta/Lang/*/Abstract-type/*

require sitting_duck

statement ok
LOAD sitting_duck;

# =============================================================================
# 1. TYPE SELECTORS across languages
# =============================================================================
# Each language uses different AST node types for the same concepts.

# Python: function_definition
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'function_definition')
ORDER BY name, start_line;
----
__init__
fetch
main
make_animal
move
process_animals
purr
speak
speak
speak

# Python: class_definition
query I
SELECT name FROM ast_select('test/data/python/css_selectors_test.py', 'class_definition')
ORDER BY name;
----
Animal
Cat
Dog

