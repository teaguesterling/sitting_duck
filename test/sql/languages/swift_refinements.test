query IT
SELECT type, semantic_type_to_string(semantic_type) as sem_type
FROM read_ast('test/data/swift/simple.swift')
WHERE type = 'associatedtype_declaration'
LIMIT 1;
----
associatedtype_declaration	DEFINITION_CLASS

