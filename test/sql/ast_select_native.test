# name: test/sql/ast_select_native.test
# group: [sql]

# Test ast_select native extraction attributes and pseudo-classes

require sitting_duck

statement ok
LOAD sitting_duck;

# =============================================================================
# Attribute selectors on native extraction fields
# =============================================================================

# [modifier=X] — check modifiers array
# Async functions should have 'async' in modifiers (bug #009 regression)
query I
SELECT COUNT(*) FROM ast_select('test/data/test_native_context.py', '.func[modifier=async]');
----
1

# [annotation*=X] — substring match on annotations
query I
SELECT COUNT(*) >= 0 FROM ast_select('test/data/python/simple.py', '.func[annotation*=pytest]');
----
true

# [qualified*=X] — substring match on qualified_name.
# .func requires the match to be a function (semantic CLASS check on base), and
# Account has __init__ / methods whose qualified_name includes "Account".
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/qualified_names.py', '.func[qualified*=Account]');
----
true

# [params=N] — parameter count
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/star_test.py', 'function_definition[params=1]');
----
2

# [signature=X] — signature_type match
query I
SELECT COUNT(*) >= 0 FROM ast_select('test/data/python/simple.py', '.func[signature=int]');
----
true

# [peek*=X] — source text content search. Row-pinned: `string` prefix-matches
# string + string_content, and recursive_match.py has "SELECT 1" literals at
# exactly these lines — a wrong-row regression cannot ship green on COUNT alone.
query II
SELECT type, start_line FROM ast_select('test/data/python/macros/recursive_match.py', 'string[peek*=SELECT]');
----
string	19
string_content	19
string	24
string_content	24
string	29
string_content	29
string	34
string_content	34
string	39
string_content	39

# [peek*=X] must not match everything: a peek filter that matches nothing in the
# file returns 0 rows, not all rows (issue #81 — NULL peek was NULL-permissive).
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py', 'string[peek*=zz_no_such_text_zz]');
----
0

# [peek^=X] — prefix match on the node's full source text. Only the call at
# line 148 starts with "db.connect".
query II
SELECT name, start_line FROM ast_select('test/data/python/sample_app.py', '.call[peek^="db.connect"]');
----
connect	148

# [peek$=X] — suffix match on the node's full source text. ast_select
# materializes peek := 'full', so the suffix is the true end of the node text
# (smart peek's first-line truncation would break this). Two calls end with
# "close()": self._conn.close() at line 47 and db.close() at line 159.
query II
SELECT name, start_line FROM ast_select('test/data/python/sample_app.py', '.call[peek$="close()"]');
----
close	47
close	159

# =============================================================================
# [signature^=X] / [signature$=X] — prefix/suffix on signature_type
# =============================================================================
# test_native_context.py: async_function -> str (line 5),
# method_with_types -> bool (line 18).

query II
SELECT name, start_line FROM ast_select('test/data/test_native_context.py', '.func[signature^=s]');
----
async_function	5

query II
SELECT name, start_line FROM ast_select('test/data/test_native_context.py', '.func[signature$=ool]');
----
method_with_types	18

# =============================================================================
# Peek filters against a table without peek materialized (issue #81)
# =============================================================================
# ast_select_from on a table parsed with peek := 'none+schema' (peek entirely
# NULL) cannot evaluate a [peek...] filter. Under NULL-definite matching that
# would silently return 0 rows — instead it raises an error with a re-parse
# hint (an all-NULL peek column always means peek was never extracted).

statement ok
CREATE TABLE zz_no_peek_ast AS SELECT * FROM read_ast('test/data/python/sample_app.py', peek := 'none+schema');

statement error
SELECT COUNT(*) FROM ast_select_from('zz_no_peek_ast', '.call[peek*=execute]');
----
no peek text

# Sanity: the same table still matches non-peek selectors normally.
query I
SELECT COUNT(*) > 0 FROM ast_select_from('zz_no_peek_ast', '.call#execute');
----
true

statement ok
DROP TABLE zz_no_peek_ast;

# =============================================================================
# Pseudo-classes over NULL columns (issue #81, second dispatch site)
# =============================================================================
# The pseudo-class dispatch had the same NULL-permissive defect as the
# attribute filters: over a table with NULL modifiers, `.call:async` returned
# every call node. NULL pseudo-class evaluations must count as "not satisfied":
# :async matches nothing, :not(:async) matches everything.

statement ok
CREATE TABLE zz_null_mods_ast AS SELECT * REPLACE (NULL::VARCHAR[] AS modifiers) FROM read_ast('test/data/python/sample_app.py');

query I
SELECT COUNT(*) FROM ast_select_from('zz_null_mods_ast', '.call:async');
----
0

query I
SELECT (SELECT COUNT(*) FROM ast_select_from('zz_null_mods_ast', '.call:not(:async)'))
     = (SELECT COUNT(*) FROM ast_select_from('zz_null_mods_ast', '.call'))
   AND (SELECT COUNT(*) FROM ast_select_from('zz_null_mods_ast', '.call')) > 0;
----
true

statement ok
DROP TABLE zz_null_mods_ast;

# =============================================================================
# CSS attribute operators
# =============================================================================

# [name^=test] — starts with
query I
SELECT COUNT(*) >= 0 FROM ast_select('test/data/python/macros/recursive_match.py', '[name^=shallow]');
----
true

# [name$=execute] — ends with
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition[name$=execute]');
----
true

# [name*=return] — contains
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition[name*=return]');
----
true

# =============================================================================
# Native extraction pseudo-classes
# =============================================================================

# :decorated — has annotations
query I
SELECT COUNT(*) >= 0 FROM ast_select('test/data/python/simple.py', '.func:decorated');
----
true

# :typed — has a signature_type
query I
SELECT COUNT(*) >= 0 FROM ast_select('test/data/python/simple.py', '.func:typed');
----
true

# :void — no return type
query I
SELECT COUNT(*) >= 0 FROM ast_select('test/data/python/simple.py', '.func:void');
----
true

# =============================================================================
# Compound: native + structural
# =============================================================================

# Functions with parameters that have return statements
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition[params=1]:has(return_statement)');
----
true

# =============================================================================
# :contains("code") — subtree structural pattern match
# =============================================================================

# Match attribute access pattern: db.execute (no parens = just the attribute)
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    '.func:contains("db.execute")');
----
6

# Exact match: return x
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py',
    '.func:contains("return x")');
----
true

# db.execute() with empty args should NOT match db.execute("SELECT 1")
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    '.func:contains("db.execute()")');
----
0

# =============================================================================
# :match("code") — current-node structural pattern match
# =============================================================================

# :match on .func asking for a call pattern returns 0 — a function_definition
# is not the root type of the parsed pattern. This is the key semantic
# difference from :contains, which checks the subtree.
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    '.func:match("db.execute")');
----
0

# :match is strictly more restrictive than :contains — the same selector with
# :match should return no more rows than with :contains.
query I
SELECT
    (SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
         '.func:match("db.execute")'))
    <=
    (SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
         '.func:contains("db.execute")'));
----
true

# Multiple :match/:contains in one selector is an error — only one pattern supported
statement error
SELECT * FROM ast_select('test/data/python/macros/recursive_match.py',
    '.func:contains("a"):contains("b")');
----
only one :match or :contains pattern per selector
