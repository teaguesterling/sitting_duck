# name: test/sql/languages/sql_language_support.test
# description: Test SQL language support functionality
# group: [languages]

require sitting_duck

# Test 1: SQL language is supported
# =================================

query I
SELECT language FROM ast_supported_languages() WHERE language = 'sql';
----
sql

# Test 2: SQL file extension auto-detection
# =========================================

query I
SELECT COUNT(*) > 0 FROM read_ast('test/data/sql/example.sql');
----
true

# Test 3: Explicit SQL language specification
# ===========================================

query I
SELECT COUNT(*) FROM read_ast('test/data/sql/example.sql', 'sql') WHERE name IS NOT NULL;
----
177

# Test 4: SQL identifier extraction
# =================================

query I
SELECT COUNT(*) FROM read_ast('test/data/sql/example.sql')
WHERE type = 'identifier';
----
34

# Test 5: SQL table references
# ============================

query I
SELECT COUNT(DISTINCT name) FROM read_ast('test/data/sql/example.sql')
WHERE type = 'identifier' AND name IN ('users', 'orders', 'customers');
----
3

# Test 6: SQL keywords
# ====================
# Note: SQL parser doesn't have a 'keyword' node type

query I
SELECT COUNT(*) FROM read_ast('test/data/sql/example.sql')
WHERE type IN ('select', 'from', 'where', 'insert', 'create_table', 'group_by', 'order_by');
----
7

# Test 7: SQL literals
# ====================

query I
SELECT COUNT(*) FROM read_ast('test/data/sql/example.sql')
WHERE type = 'literal';
----
7

# Test 8: SQL semantic types
# ==========================

query ITI
SELECT type, semantic_type, COUNT(*) as count
FROM read_ast('test/data/sql/example.sql')
WHERE type IN ('identifier', 'literal', 'comment')
GROUP BY type, semantic_type
ORDER BY type;
----
comment	METADATA_COMMENT	3
identifier	NAME_IDENTIFIER	34
literal	LITERAL_ATOMIC	7

# Test 9: SQL tree structure validation
# =====================================

query II
SELECT MAX(depth) as max_depth, COUNT(*) as total_nodes
FROM read_ast('test/data/sql/example.sql');
----
9	177

# Test 10: SQL column references
# ==============================

query I
SELECT COUNT(*) FROM read_ast('test/data/sql/example.sql')
WHERE type = 'object_reference';
----
15

# =============================================================================
# CREATE FUNCTION/MACRO name extraction (#37)
# =============================================================================

# Test 11: create_function nodes get DEFINITION_FUNCTION semantic type
# ====================================================================

query TT
SELECT type, semantic_type
FROM read_ast('test/data/sql/create_function_example.sql')
WHERE type = 'create_function'
ORDER BY node_id
LIMIT 1;
----
create_function	DEFINITION_FUNCTION

# Test 12: Function names are correctly extracted (not "CREATE")
# ==============================================================

query TT
SELECT name, type
FROM read_ast('test/data/sql/create_function_example.sql')
WHERE type = 'create_function'
ORDER BY start_line;
----
get_user_name	create_function
calculate_total	create_function

# Test 13: keyword_create has PARSER_SYNTAX, not DEFINITION_CLASS
# ===============================================================

query TT
SELECT type, semantic_type
FROM read_ast('test/data/sql/create_function_example.sql')
WHERE type = 'keyword_create'
ORDER BY node_id
LIMIT 1;
----
keyword_create	PARSER_SYNTAX

# Test 14: keyword_function has PARSER_SYNTAX, not DEFINITION_FUNCTION
# ====================================================================

query TT
SELECT type, semantic_type
FROM read_ast('test/data/sql/create_function_example.sql')
WHERE type = 'keyword_function'
ORDER BY node_id
LIMIT 1;
----
keyword_function	PARSER_SYNTAX

# Test 15: CREATE TABLE and CREATE VIEW also extract names correctly
# ==================================================================

query TT
SELECT name, type
FROM read_ast('test/data/sql/create_function_example.sql')
WHERE type IN ('create_table', 'create_view')
ORDER BY start_line;
----
products	create_table
active_users	create_view

# Test 16: ast_definitions returns correct SQL definitions without duplicates
# ===========================================================================

statement ok
CREATE TEMP TABLE sql_fn_ast AS SELECT * FROM read_ast('test/data/sql/create_function_example.sql');

query TT
SELECT name, definition_type FROM ast_definitions('sql_fn_ast')
WHERE definition_type IN ('function', 'class')
ORDER BY start_line;
----
get_user_name	function
calculate_total	function
products	class
active_users	class