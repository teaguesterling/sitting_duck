# name: test/sql/ast_select_pseudo_classes.test
# group: [sql]

# Test ast_select pseudo-classes: positional, structural, scope, ordering

require sitting_duck

statement ok
LOAD sitting_duck;

# =============================================================================
# Standard CSS positional pseudo-classes
# =============================================================================

# :first-child — first sibling (sibling_index = 0)
# The nested `inner` functions are the only function_definitions at sibling_index 0
query II
SELECT name, depth
FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition:first-child')
ORDER BY start_line;
----
inner	3
inner	3

# :last-child — last sibling at depth 1
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition:last-child')
WHERE depth = 1;
----
outer_no_execute	37

# :nth-child(2) — second sibling (1-based) at depth 1
# shallow_return is sibling_index 1 (comment is 0), so nth-child(2)
query II
SELECT name, start_line
FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition:nth-child(2)')
WHERE depth = 1;
----
shallow_return	2

# :empty — nodes with no children
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py', ':empty');
----
true

# :root — depth = 0
query I
SELECT type FROM ast_select('test/data/python/macros/recursive_match.py', ':root');
----
module

# =============================================================================
# Custom structural pseudo-classes
# =============================================================================

# :named — has a non-empty name
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py', 'function_definition:named');
----
10

# :syntax — syntax-only tokens (keywords, punctuation)
# Bare `if` matches both keyword and statement; if:syntax gets only keywords
query I
SELECT COUNT(DISTINCT type)
FROM ast_select('test/data/python/macros/recursive_match.py', 'if:syntax');
----
1

# :definition — NAME_DEFINITION flag
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:definition');
----
10

# :reference — NAME_REFERENCE flag
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/macros/recursive_match.py',
    'identifier:reference');
----
true

# :scope (bare) — nodes that are scope boundaries
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:scope');
----
10

# =============================================================================
# :scope(type) — within nearest ancestor scope
# =============================================================================

# return_statement:scope(function) — returns within their DIRECT function
# Should NOT count returns in nested functions as belonging to the outer function
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'return_statement:scope(function)');
----
5

# =============================================================================
# :precedes(type) and :follows(type)
# =============================================================================

# :precedes(function_definition) — comments that come before a function def
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'comment:precedes(function_definition)');
----
3

# :follows(class_definition) — functions defined after a class
query I
SELECT COUNT(*) > 0 FROM ast_select('test/data/python/qualified_names.py',
    'function_definition:follows(class_definition)');
----
true

# =============================================================================
# Compound pseudo-classes
# =============================================================================

# :named:definition — named definitions only
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    ':named:definition');
----
10

# function_definition:first-child:has(return_statement) — first-child functions with returns
# The inner functions are first-child and have no returns themselves
query I
SELECT COUNT(*) FROM ast_select('test/data/python/macros/recursive_match.py',
    'function_definition:first-child:has(return_statement)');
----
0
